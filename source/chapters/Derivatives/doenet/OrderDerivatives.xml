<setup>
  <boolean name="hint">false</boolean>
  <boolean name="dfGraph">false</boolean>
  <function name="f">
    (x)^2(x+7)(x-6)(x+5)(x-2)/2000
  </function>
  <point name="P">
    (1,1)
    <constrainTo>
      $f
    </constrainTo>
    <label><m>($P.x, $P.y)</m></label>
  </point>
  <derivative name="df" styleNumber="2">
    $f
  </derivative>
 <function name="tangent" domain="[$P.x-2, $P.x+2]" styleNumber="2">
   $$df($P.x)(x-$P.x)+$P.y
 </function>
  <numberList name="pList">
    -5 -4 -2 0 4
  </numberList>
</setup>

<p>
  <em>Instructions:</em> Use the graph of the function <m>f(x)</m> below to order the values of <m>f'</m> from least to greatest. 
</p>

<conditionalContent>
  <case condition="$dfGraph = true">
    <sideBySide>
      <p><me>\text{Graph of } f(x)</me></p>
      <p><me>\text{Graph of } f'(x)</me></p>
    </sideBySide>
  </case>
</conditionalContent>

<sideBySide>
  <graph fixAxes xMin="-6" xMax="6" yMin="-5" yMax="3" identicalAxisScales>
    $f
    <conditionalContent>
      <case condition="$hint=true">
        $P
        $tangent
      </case>
    </conditionalContent>
    <shortDescription>
      Graph of a polynomial function, curving up and down.
    </shortDescription>
  </graph>
  <conditionalContent>
    <case condition="$dfGraph = true">
      <graph fixAxes xMin="-6" xMax="6" yMin="-5" yMax="3" identicalAxisScales>
        $df
        <point styleNumber="2">
          ($P.x, $$df($P.y))
          <constrainTo>
            $df
          </constrainTo>
          <label><m>($P.x, $$df($P.y))</m></label>
        </point>
        <shortDescription>
          Graph of the derivative of the polynomial function, curving up and down.
        </shortDescription>
      </graph>
    </case>
  </conditionalContent>
</sideBySide>

<updateValue type="boolean" target="$hint" newValue="not $hint">
  <label>
    <conditionalContent>
      <case condition="$hint = true">
        Hide Hint
      </case>
      <case condition="$hint = false">
        Show Hint
      </case>
    </conditionalContent>
  </label>
</updateValue>

<sideBySide>
  <p>A. <m>f'($pList[1])</m></p>
  <p>B. <m>f'($pList[2])</m></p>
  <p>C. <m>f'($pList[3])</m></p>
  <p>D. <m>f'($pList[4])</m></p>
  <p>E. <m>f'($pList[5])</m></p>
</sideBySide>
<p>
  Input the letters that correspond with the derivative values:
</p>
<p>
  <answer caseInsensitiveMatch>
    <textInput width="40px" name="first">
      <shortDescription>
        First value
      </shortDescription>
    </textInput>
    <award><when>$first=e</when></award>
  </answer>
  &lt;
  <answer caseInsensitiveMatch>
    <textInput width="40px" name="second">
      <shortDescription>
        Second value
      </shortDescription>
    </textInput>
    <award><when>$second=c</when></award>
  </answer>
  &lt;
  <answer caseInsensitiveMatch>
    <textInput width="40px" name="third">
      <shortDescription>
        Third value
      </shortDescription>
    </textInput>
    <award><when>$third=d</when></award>
  </answer>
  &lt;
  <answer caseInsensitiveMatch>
    <textInput width="40px" name="third">
      <shortDescription>
        Fourth value
      </shortDescription>
    </textInput>
    <award><when>$third=v</when></award>
  </answer>
  &lt;
  <answer caseInsensitiveMatch>
    <textInput width="40px" name="fourth">
      <shortDescription>
        Fifth value
      </shortDescription>
    </textInput>
    <award><when>$fourth=a</when></award>
  </answer>
</p>

<updateValue type="boolean" target="$dfGraph" newValue="not $dfGraph">
  <label>
    <conditionalContent>
      <case condition="$dfGraph = true">
        Hide the Even Bigger Hint
      </case>
      <case condition="$dfGraph = false">
        Show an Even Bigger Hint
      </case>
    </conditionalContent>
  </label>
</updateValue>