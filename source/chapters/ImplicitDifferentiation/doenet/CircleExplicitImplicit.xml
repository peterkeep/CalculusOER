<setup>
  <boolean name="showExplicit">false</boolean>
</setup>
<updateValue type="boolean" target="$showExplicit" newValue="not $showExplicit">
  <label>
    <conditionalContent>
      <case condition="$showExplicit = true">
        Show the implicitly defined circle
      </case>
      <case condition="$showExplicit = false">
        Show the explicitly defined circle
      </case>
    </conditionalContent>
  </label>
</updateValue> 

    <conditionalContent>
      <case condition="$showExplicit = true">
        <graph xmin="-1.5" xmax="1.5" ymin="-1.5" ymax="1.5" identicalAxisScales size="small"
  showBorder="false" showNavigation="false" fixAxes>
          <function styleNumber="2">sqrt(1-x^2)</function>
          <label anchor="(-0.7, 1.1)" styleNumber="2" fixed><m>y=\sqrt{1-x^2}</m></label>
          <function styleNumber="4">-sqrt(1-x^2)</function>
          <label anchor="(-0.8, -1.1)" styleNumber="4" fixed><m>y=-\sqrt{1-x^2}</m></label>
          <shortDescription>
            The upper half of the unit circle defined as y equals the square root of 1 minus x squared, and the lower half defined as y equals the negative square root of 1 minus x squared.
          </shortDescription>
        </graph>
      </case>
      <case condition="$showExplicit = false">
        <graph xmin="-1.5" xmax="1.5" ymin="-1.5" ymax="1.5" identicalAxisScales size="small" 
  showBorder="false" showNavigation="false" fixAxes >
          <circle/>
          <label anchor="(-0.7, 1.1)" fixed><m>x^2+y^2=1</m></label>
          <shortDescription>
            Unit circle defined as x squared plus y squared equals 1.
          </shortDescription>
        </graph>
      </case>
    </conditionalContent>