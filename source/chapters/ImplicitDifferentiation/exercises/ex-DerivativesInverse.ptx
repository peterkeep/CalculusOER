<exercises xml:id="ex-DerivativesInverse">
    <exercise>
        <introduction>
            <p>
                Find the derivatives of the following functions.
            </p>
        </introduction>
        <task>
            <statement>
                <p>
                    <m>y=7^x</m>
                </p>
            </statement>
            <solution>
                <p>
                    <m>y' = 7^x\ln(7)</m>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = \log_3(x)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <m>y' = \frac{1}{x\ln(3)}</m>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>A(t) = 400(1.001)^{12t}</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>A'(t) \amp = 400(1.001)^{12t}\ln(1.001)\frac{d}{dt}(12t)</mrow>
                        <mrow> \amp = 4800(1.001)^{12t}\ln(1.001)</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = \dfrac{3^x}{3^x+1}</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = \frac{(3^x+1)(3^x)\ln(3) - (3^x)(3^x)\ln(3)}{(3^x+1)^2}</mrow>
                        <mrow>f'(x) \amp = \frac{3^x\ln(3)}{(3^x+1)^2}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>g(x) = \ln(x^2+1)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>g'(x) \amp = \frac{1}{x^2+1} \ddx{x^2+1}</mrow> 
                        <mrow> \amp = \frac{2x}{x^2+1}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>s(x) = (e^x)(x^e)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>s'(x) \amp = (e^x)(x^e)+(e^x)(ex^{e-1})</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = \ln(4x^3)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>y' \amp = \frac{1}{4x^3}\ddx{4x^3}</mrow>
                        <mrow> \amp = \frac{12x^2}{4x^3}</mrow>
                        <mrow> \amp = \frac{3}{x}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = \ln(\sqrt{x^4+x^2})</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>y' \amp = \frac{1}{\sqrt{x^4+x^2}}\ddx{\sqrt{x^4+x^2}}</mrow>
                        <mrow> \amp = \frac{1}{\sqrt{x^4+x^2}} \left(\frac{1}{2\sqrt{x^4+x^2}}\right)\ddx{x^4+x^2}</mrow>
                        <mrow> \amp = \frac{4x^3 + 2x}{2(x^4+x^2)}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = x\ln(x)-x</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>y' \amp = x\left(\frac{1}{x}\right) + \ln(x) - 1</mrow>
                        <mrow> \amp = \ln(x)</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = \sin(4^x)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>y' \amp = \cos(4^x)4^x\ln(4)</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = e^x\ln(x)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>y' \amp = e^x(\ln(x)) + e^x\left(\frac{1}{x}\right)</mrow>
                        <mrow> \amp = e^x\left(\ln(x)+\frac{1}{x}\right)</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>r(\theta) = (\theta^2) (5^\theta)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>r'(\theta) \amp = (2\theta)(5^{\theta}) + (\theta^2)(5^{\theta}\ln(5))</mrow>
                        <mrow> \amp = \theta 5^\theta(2 + \theta\ln(5))</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = \ln(\ln(x))</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>y' \amp = \frac{1}{\ln(x)}\ddx{\ln(x)}</mrow>
                        <mrow> \amp = \frac{1}{\ln(x)}\left(\frac{1}{x}\right)</mrow>
                        <mrow> \amp = \frac{1}{x\ln(x)}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>y = -\ln(\cos(x))</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>y' \amp = -\frac{1}{\cos(x)}(-\sin(x))</mrow>
                        <mrow> \amp = \frac{\sin(x)}{\cos(x)}</mrow>
                        <mrow> \amp = \tan(x)</mrow>
                    </md>
                </p>
            </solution>
        </task>
    </exercise>
    <exercise>
        <introduction>
            <p>
                Find the derivatives of the following functions.
            </p>
        </introduction>
        <task>
            <statement>
                <p>
                    <m>f(x) = \sin^{-1}(5x)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = \frac{1}{\sqrt{1-(5x)^2}} \ddx{5x}</mrow>
                        <mrow> \amp = \frac{5}{\sqrt{1-25x^2}}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = x^2\tan^{-1}(x)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = 2x\tan^{-1}(x) + x^2\left(\frac{1}{x^2+1}\right)</mrow>
                        <mrow> \amp = 2x\tan^{-1}(x) + \frac{x^2}{x^2+1}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = (\sec^{-1}(x))^3</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = 3\left(\sec^{-1}(x)\right)^2 \left(\frac{1}{|x|\sqrt{x^2-1}}\right)</mrow>
                        <mrow> \amp = \frac{3\left(\sec^{-1}(x)\right)^2}{|x|\sqrt{x^2-1}}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = \cos^{-1}\left(\frac{1}{x}\right)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = -\frac{1}{\sqrt{1-\left(\frac{1}{x}\right)^2}}\ddx{\frac{1}{x}}</mrow>
                        <mrow> \amp = -\frac{1}{\sqrt{1-\frac{1}{x^2}}}\left(-\frac{1}{x^2}\right)</mrow>
                        <mrow> \amp = \frac{1}{x^2\sqrt{1-\frac{1}{x^2}}}</mrow>
                        <mrow> \amp = \frac{1}{\sqrt{x^4-x^2}}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = \ln(\sin^{-1}(x))</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = \frac{1}{\sin^{-1}(x)}\ddx{\sin^{-1}(x)}</mrow>
                        <mrow> \amp = \frac{1}{\sin^{-1}(x)}\left(\frac{1}{\sqrt{1-x^2}}\right)</mrow>
                        <mrow> \amp = \frac{1}{\sin^{-1}(x)\sqrt{1-x^2}}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = \cot^{-1}(e^{2x})</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = -\frac{1}{1+\left(e^{2x}\right)^2}\ddx{e^2x}</mrow>
                        <mrow> \amp = -\frac{2e^{2x}}{1+e^{4x}}</mrow>
                    </md>
                </p>
            </solution>
        </task>
    </exercise>
    <exercise>
        <introduction>
            <p>
                Find the equation of the line tangent to the graph of the following functions at the point listed.
            </p>
        </introduction>
        <task>
            <statement>
                <p>
                    <m>f(x) = \tan^{-1}(x)</m> at <m>\left(1,\frac{\pi}{4}\right)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = \frac{1}{x^2+1}</mrow>
                        <mrow>f'(1) \amp = \frac{1}{2}</mrow>
                        <mrow>y \amp = \frac{1}{2}(x-1)+\frac{\pi}{4}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = \sin^{-1}\left(\frac{x}{4} \right)</m> at <m>\left(2,\frac{\pi}{6}\right)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = \frac{1}{4\sqrt{1-\frac{x^2}{16}}}</mrow>
                        <mrow>f'(2) \amp = \frac{1}{4\sqrt{\frac{3}{4}}}</mrow>
                        <mrow> \amp = \frac{1}{2\sqrt{3}}</mrow>
                        <mrow>y \amp = \frac{1}{2\sqrt{3}}(x-2)+\frac{\pi}{6}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = \cos^{-1}(x^2)</m> at <m>\left(\frac{1}{\sqrt{2}}, \frac{\pi}{3}\right)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = -\frac{2x}{\sqrt{1-x^4}}</mrow>
                        <mrow>f'(1/\sqrt{2}) \amp = -\frac{4}{\sqrt{6}} </mrow>
                        <mrow>y \amp = -\frac{4}{\sqrt{6}}\left(x-\frac{1}{\sqrt{2}}\right) + \frac{\pi}{3}</mrow>
                    </md>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    <m>f(x) = \sec^{-1}(e^x)</m> at <m>\left(\ln(2), \frac{\pi}{3}\right)</m>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow>f'(x) \amp = \frac{1}{\sqrt{e^{2x}-1}}</mrow>
                        <mrow>f'(\ln(2)) \amp = \frac{1}{\sqrt{3}}</mrow>
                        <mrow>y \amp = \frac{1}{\sqrt{3}}(x-\ln(2))+\frac{\pi}{3}</mrow>
                    </md>
                </p>
            </solution>
        </task>
    </exercise>
    <exercise>
        <introduction>
            <p>
                Graph the function <m>f(x) = \tan^{-1}(x)-x^3-x</m> using a graphing utility like Desmos.
            </p>
        </introduction>
        <task>
            <statement>
                <p>
                    Find <m>f'(x)</m>.
                </p>
            </statement>
            <solution>
                <p>
                    <m>f'(x) = \dfrac{1}{x^2+1} - 2x -1</m>
                </p>
            </solution>
        </task>
        <task>
            <statement>
                <p>
                    Graph <m>f'(x)</m> using a graphing utility like Desmos.
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Where is <m>f'(x)=0</m>?
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Where does <m>f(x)</m> have a horizontal tangent line?
                </p>
            </statement>
        </task>
    </exercise>
</exercises>